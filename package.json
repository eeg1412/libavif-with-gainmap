{
  "name": "libavif-with-gainmap",
  "version": "0.1.12",
  "description": "Convert JPEG gain map images to AVIF gain map images using libavif.",
  "license": "MIT",
  "type": "commonjs",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eeg1412/libavif-with-gainmap.git"
  },
  "bugs": {
    "url": "https://github.com/eeg1412/libavif-with-gainmap/issues"
  },
  "homepage": "https://github.com/eeg1412/libavif-with-gainmap#readme",
  "main": "src/index.js",
  "bin": {
    "avif-gainmap": "bin/avif-gainmap.js"
  },
  "files": [
    "bin",
    "docs",
    "native",
    "scripts",
    "src",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "optionalDependencies": {
    "libavif-with-gainmap-darwin-arm64": "0.1.12",
    "libavif-with-gainmap-darwin-x64": "0.1.12",
    "libavif-with-gainmap-linux-arm64": "0.1.12",
    "libavif-with-gainmap-linux-x64": "0.1.12",
    "libavif-with-gainmap-win32-x64": "0.1.12"
  },
  "scripts": {
    "test": "node --test",
    "build:libavif": "node scripts/build-libavif.js",
    "prepare-platform-packages": "node scripts/prepare-platform-packages.js",
    "check-prebuilt": "node scripts/check-prebuilt.js --current",
    "check-prebuilt:all": "node scripts/check-prebuilt.js --all"
  },
  "keywords": [
    "avif",
    "gainmap",
    "hdr",
    "ultrahdr",
    "libavif",
    "jpeg"
  ]
}
